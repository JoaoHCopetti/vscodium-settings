{
  "workbench.colorCustomizations": {
    "editorSuggestWidget.selectedBackground": "#343D46",
    "quickInputList.focusBackground": "#343D46",
    "list.hoverBackground": "#343D46",
    "list.inactiveFocusBackground": "#343D46",
    "list.inactiveSelectionBackground": "#343D46",
    "list.activeSelectionBackground": "#343D46",
  },
  "syncSettings.additionalFiles": [],
  "security.workspace.trust.untrustedFiles": "open",
  "workbench.productIconTheme": "material-product-icons",
  "workbench.iconTheme": "material-icon-theme",
  "material-icon-theme.folders.theme": "classic",
  "editor.fontFamily": "Source Code Pro, Menlo, Monaco, 'Courier New', monospace",
  "editor.lineHeight": 1.6,
  "editor.fontSize": 15,
  "window.commandCenter": false,
  "workbench.tree.indent": 20,
  "workbench.tree.renderIndentGuides": "always",
  "explorer.compactFolders": false,
  "explorer.confirmDelete": false,
  "editor.smoothScrolling": false,
  "editor.formatOnSave": true,
  "[javascript][typescript][javascriptreact][typescriptreact][vue]": {
    "editor.defaultFormatter": "dbaeumer.vscode-eslint",
  },
  "php.executablePath": "/usr/bin/php",
  "editor.multiCursorModifier": "ctrlCmd",
  "emmet.triggerExpansionOnTab": true,
  "workbench.list.smoothScrolling": false,
  "php.inlayHints.parameters.enabled": false,
  "explorer.confirmDragAndDrop": false,
  "editor.suggestOnTriggerCharacters": true,
  "editor.quickSuggestions": {
    "strings": "on",
  },
  "php.inlayHints.insertOnDoubleClick": false,
  "php.inlayHints.parameters.byReference": false,
  "php.inlayHints.types.lambdaParameter": false,
  "php.inlayHints.types.return": false,
  "php.problems.exclude": {
    "**/*": [
      "php_to_string_interpolation"
    ],
  },
  "cSpell.language": "en,pt_BR",
  "js/ts.updateImportsOnFileMove.enabled": "always",
  "security.promptForLocalFileProtocolHandling": false,
  "window.customTitleBarVisibility": "never",
  "window.menuBarVisibility": "toggle",
  "workbench.startupEditor": "none",
  "eslint.probe": [
    "astro",
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact",
    "html",
    "mdx",
    "vue",
    "markdown",
    "json",
    "jsonc",
    "jsx",
  ],
  "[php]": {
    "editor.defaultFormatter": "DEVSENSE.phptools-vscode",
  },
  "editor.largeFileOptimizations": false,
  "editor.suggestSelection": "recentlyUsedByPrefix",
  "telemetry.feedback.enabled": false,
  "git.blame.statusBarItem.enabled": false,
  "clang-tidy.fixOnSave": true,
  "c-cpp-compile-run.c-compiler": "clang",
  "c-cpp-compile-run.cpp-compiler": "clang++",
  "c-cpp-compile-run.should-show-notifications": false,
  "git.openRepositoryInParentFolders": "never",
  "Laravel.phpEnvironment": "local",
  "workbench.editorAssociations": {
    "*.vdf": "default",
  },
  "files.saveConflictResolution": "overwriteFileOnDisk",
  "css.enabledLanguages": [
    "vue",
    "html"
  ],
  "auto-rename-tag.activationOnLanguage": [
    "*"
  ],
  "ollama-autocoder.model": "deepseek-coder-v2:16b",
  "privy.autocomplete.model": "deepseek-coder-v2:16b",
  "privy.model": "custom",
  "privy.customModel": "deepseek-coder-v2:16b",
  "privy.autocomplete.mode": "manual",
  "privy.syntaxHighlighting.useVisualStudioCodeColors": true,
  "privy.indexRepository.enabled": true,
  "vscode-ollama.model": "deepseek-coder-v2:16b",
  "codesnap.shutterAction": "copy",
  "continue.enableTabAutocomplete": false,
  "intelliphp.inlineSuggestionsEnabled": false,
  "[python]": {
    "editor.defaultFormatter": "charliermarsh.ruff",
  },
  "ruff.fixAll": true,
  "ruff.path": [
    ".venv/bin/ruff"
  ],
  "editor.codeActionsOnSave": {
    "source.fixAll.ruff": "always",
    "source.organizeImports.ruff": "always",
    "source.fixAll.eslint": "always"
  },
  "ruff.format.backend": "uv",
  "ty.inlayHints.callArgumentNames": false,
  "ty.inlayHints.variableTypes": false,
  "ruff.importStrategy": "useBundled",
  "git.confirmSync": false,
  "js/ts.preferences.useAliasesForRenames": false,
  "cSpell.userWords": [
    "LOTOFACIL",
    "Mollama"
  ],
  "php.codeActions.enabled": false,
  "git.enableSmartCommit": true,
  "workbench.colorTheme": "Oceanic Next",
}